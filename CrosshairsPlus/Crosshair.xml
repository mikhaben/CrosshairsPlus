<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/">

    <!-- Main Crosshair Frame -->
    <Frame name="CrosshairsPlusFrame" parent="UIParent" hidden="true" frameStrata="BACKGROUND" frameLevel="0">
        <Size>
            <AbsDimension x="64" y="64"/>
        </Size>

        <Layers>
            <!-- Core Circle Layer (must be first for relativeKey references) -->
            <Layer level="ARTWORK">
                <Texture parentKey="Core" file="Interface\AddOns\CrosshairsPlus\Assets\core">
                    <Size>
                        <AbsDimension x="96" y="96"/>
                    </Size>
                    <Anchors>
                        <Anchor point="CENTER"/>
                    </Anchors>
                </Texture>

                <!-- Core Glow Overlay -->
                <Texture parentKey="CoreGlow" file="Interface\AddOns\CrosshairsPlus\Assets\ringSolid_outerGlow" alphaMode="ADD">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.Core" relativePoint="TOPLEFT"/>
                        <Anchor point="BOTTOMRIGHT" relativeKey="$parent.Core" relativePoint="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>

            <!-- Shadow Layer (behind everything) -->
            <Layer level="BACKGROUND" textureSubLevel="-1">
                <Texture parentKey="CoreShadow" file="Interface\AddOns\CrosshairsPlus\Assets\shadow">
                    <Color r="0" g="0" b="0" a="0.5"/>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.Core" relativePoint="TOPLEFT" x="-4" y="4"/>
                        <Anchor point="BOTTOMRIGHT" relativeKey="$parent.Core" relativePoint="BOTTOMRIGHT" x="4" y="-4"/>
                    </Anchors>
                </Texture>
            </Layer>

            <!-- Directional Lines Layer -->
            <Layer level="BACKGROUND">
                <!-- Top Line -->
                <Texture parentKey="TopLine" alphaMode="ADD">
                    <Color r="1" g="1" b="1" a="1"/>
                    <Size>
                        <AbsDimension x="1" y="2560"/>
                    </Size>
                    <Anchors>
                        <Anchor point="BOTTOM" relativeKey="$parent.Core" relativePoint="TOP"/>
                    </Anchors>
                </Texture>

                <!-- Bottom Line -->
                <Texture parentKey="BottomLine" alphaMode="ADD">
                    <Color r="1" g="1" b="1" a="1"/>
                    <Size>
                        <AbsDimension x="1" y="2560"/>
                    </Size>
                    <Anchors>
                        <Anchor point="TOP" relativeKey="$parent.Core" relativePoint="BOTTOM"/>
                    </Anchors>
                </Texture>

                <!-- Left Line -->
                <Texture parentKey="LeftLine" alphaMode="ADD">
                    <Color r="1" g="1" b="1" a="1"/>
                    <Size>
                        <AbsDimension x="2560" y="1"/>
                    </Size>
                    <Anchors>
                        <Anchor point="RIGHT" relativeKey="$parent.Core" relativePoint="LEFT"/>
                    </Anchors>
                </Texture>

                <!-- Right Line -->
                <Texture parentKey="RightLine" alphaMode="ADD">
                    <Color r="1" g="1" b="1" a="1"/>
                    <Size>
                        <AbsDimension x="2560" y="1"/>
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT" relativeKey="$parent.Core" relativePoint="RIGHT"/>
                    </Anchors>
                </Texture>

                <!-- Animated Arrows -->
                <Texture parentKey="Arrows" file="Interface\AddOns\CrosshairsPlus\Assets\4Arrows" alphaMode="ADD">
                    <Color r="1" g="0" b="0" a="1"/>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.Core" relativePoint="TOPLEFT" x="-16" y="16"/>
                        <Anchor point="BOTTOMRIGHT" relativeKey="$parent.Core" relativePoint="BOTTOMRIGHT" x="16" y="-16"/>
                    </Anchors>
                    <Animations>
                        <AnimationGroup parentKey="Rotate" looping="REPEAT">
                            <Rotation smoothing="NONE" duration="5" order="1" degrees="-360"/>
                        </AnimationGroup>
                    </Animations>
                </Texture>
            </Layer>

            <!-- Text Overlays -->
            <Layer level="OVERLAY">
                <!-- Target Name -->
                <FontString parentKey="NameText" inherits="GameFontNormal" justifyH="CENTER">
                    <Anchors>
                        <Anchor point="BOTTOM" relativeKey="$parent.Core" relativePoint="TOP" x="0" y="10"/>
                    </Anchors>
                    <Color r="1" g="1" b="1"/>
                </FontString>

                <!-- Range Display -->
                <FontString parentKey="RangeText" inherits="GameFontNormalSmall" justifyH="CENTER">
                    <Anchors>
                        <Anchor point="TOP" relativeKey="$parent.Core" relativePoint="BOTTOM" x="0" y="-5"/>
                    </Anchors>
                    <Color r="1" g="1" b="0"/>
                </FontString>
            </Layer>
        </Layers>

        <Scripts>
            <OnLoad>
                -- Start rotation animation
                if self.Arrows and self.Arrows.Rotate then
                    self.Arrows.Rotate:Play()
                end
                print("|cff00ff00CrosshairsPlus|r: Frame OnLoad executed")
            </OnLoad>
        </Scripts>
    </Frame>

</Ui>
