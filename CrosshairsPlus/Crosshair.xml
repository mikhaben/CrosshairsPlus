<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/">

    <!-- Main Crosshair Frame -->
    <Frame name="CrosshairsPlusFrame" parent="UIParent" hidden="true" frameStrata="LOW">
        <Size>
            <AbsDimension x="64" y="64"/>
        </Size>

        <Layers>
            <!-- Core Circle Layer (must be first for relativeKey references) -->
            <Layer level="ARTWORK">
                <Texture parentKey="Core" file="Interface\AddOns\CrosshairsPlus\Assets\Circle0">
                    <Size>
                        <AbsDimension x="96" y="96"/>
                    </Size>
                    <Anchors>
                        <Anchor point="CENTER"/>
                    </Anchors>
                </Texture>

                <!-- Core Glow Overlay -->
                <Texture parentKey="CoreGlow" file="Interface\AddOns\CrosshairsPlus\Assets\CircleGlow" alphaMode="ADD">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.Core" relativePoint="TOPLEFT"/>
                        <Anchor point="BOTTOMRIGHT" relativeKey="$parent.Core" relativePoint="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>

            <!-- Shadow Layer (behind everything) -->
            <Layer level="BACKGROUND" textureSubLevel="-1">
                <Texture parentKey="CoreShadow" file="Interface\AddOns\CrosshairsPlus\Assets\CircleShadow">
                    <Color r="0" g="0" b="0" a="0.5"/>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.Core" relativePoint="TOPLEFT" x="-4" y="4"/>
                        <Anchor point="BOTTOMRIGHT" relativeKey="$parent.Core" relativePoint="BOTTOMRIGHT" x="4" y="-4"/>
                    </Anchors>
                </Texture>
            </Layer>

            <!-- Directional Lines Layer -->
            <Layer level="BACKGROUND">
                <!-- Top Line -->
                <Texture parentKey="TopLine">
                    <Color r="1" g="1" b="1" a="1"/>
                    <Size>
                        <AbsDimension x="1" y="2560"/>
                    </Size>
                    <Anchors>
                        <Anchor point="BOTTOM" relativeKey="$parent.Core" relativePoint="TOP"/>
                    </Anchors>
                </Texture>

                <!-- Bottom Line -->
                <Texture parentKey="BottomLine">
                    <Color r="1" g="1" b="1" a="1"/>
                    <Size>
                        <AbsDimension x="1" y="2560"/>
                    </Size>
                    <Anchors>
                        <Anchor point="TOP" relativeKey="$parent.Core" relativePoint="BOTTOM"/>
                    </Anchors>
                </Texture>

                <!-- Left Line -->
                <Texture parentKey="LeftLine">
                    <Color r="1" g="1" b="1" a="1"/>
                    <Size>
                        <AbsDimension x="2560" y="1"/>
                    </Size>
                    <Anchors>
                        <Anchor point="RIGHT" relativeKey="$parent.Core" relativePoint="LEFT"/>
                    </Anchors>
                </Texture>

                <!-- Right Line -->
                <Texture parentKey="RightLine">
                    <Color r="1" g="1" b="1" a="1"/>
                    <Size>
                        <AbsDimension x="2560" y="1"/>
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT" relativeKey="$parent.Core" relativePoint="RIGHT"/>
                    </Anchors>
                </Texture>

                <!-- Arrow - Top -->
                <Texture parentKey="ArrowTop" file="Interface\AddOns\CrosshairsPlus\Assets\Arrow0" alphaMode="ADD">
                    <Color r="1" g="1" b="1" a="1"/>
                    <Size>
                        <AbsDimension x="32" y="32"/>
                    </Size>
                    <Anchors>
                        <Anchor point="BOTTOM" relativeKey="$parent.Core" relativePoint="TOP" x="0" y="8"/>
                    </Anchors>
                    <TexCoords left="0" right="1" top="0" bottom="1"/>
                </Texture>

                <!-- Arrow - Right -->
                <Texture parentKey="ArrowRight" file="Interface\AddOns\CrosshairsPlus\Assets\Arrow0" alphaMode="ADD">
                    <Color r="1" g="1" b="1" a="1"/>
                    <Size>
                        <AbsDimension x="32" y="32"/>
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT" relativeKey="$parent.Core" relativePoint="RIGHT" x="8" y="0"/>
                    </Anchors>
                    <TexCoords left="0" right="1" top="0" bottom="1"/>
                </Texture>

                <!-- Arrow - Bottom -->
                <Texture parentKey="ArrowBottom" file="Interface\AddOns\CrosshairsPlus\Assets\Arrow0" alphaMode="ADD">
                    <Color r="1" g="1" b="1" a="1"/>
                    <Size>
                        <AbsDimension x="32" y="32"/>
                    </Size>
                    <Anchors>
                        <Anchor point="TOP" relativeKey="$parent.Core" relativePoint="BOTTOM" x="0" y="-8"/>
                    </Anchors>
                    <TexCoords left="0" right="1" top="0" bottom="1"/>
                </Texture>

                <!-- Arrow - Left -->
                <Texture parentKey="ArrowLeft" file="Interface\AddOns\CrosshairsPlus\Assets\Arrow0" alphaMode="ADD">
                    <Color r="1" g="1" b="1" a="1"/>
                    <Size>
                        <AbsDimension x="32" y="32"/>
                    </Size>
                    <Anchors>
                        <Anchor point="RIGHT" relativeKey="$parent.Core" relativePoint="LEFT" x="-8" y="0"/>
                    </Anchors>
                    <TexCoords left="0" right="1" top="0" bottom="1"/>
                </Texture>
            </Layer>

            <!-- Text Overlays -->
            <Layer level="OVERLAY">
                <!-- Range Display -->
                <FontString parentKey="RangeText" inherits="GameFontNormalSmall" justifyH="CENTER">
                    <Anchors>
                        <Anchor point="TOP" relativeKey="$parent.Core" relativePoint="BOTTOM" x="0" y="-5"/>
                    </Anchors>
                    <Color r="1" g="1" b="0"/>
                </FontString>

                <!-- Target Info Display -->
                <FontString parentKey="TargetInfoText" inherits="GameFontNormalSmall" justifyH="CENTER">
                    <Anchors>
                        <Anchor point="BOTTOM" relativeKey="$parent.Core" relativePoint="TOP" x="0" y="5"/>
                    </Anchors>
                    <Color r="1" g="1" b="1"/>
                </FontString>
            </Layer>
        </Layers>
    </Frame>

</Ui>
